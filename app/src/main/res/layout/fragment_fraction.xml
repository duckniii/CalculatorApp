<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp" android:gravity="center"
    android:background="#000000">

    <TextView android:text="Fraction Calculator"
        android:textSize="20sp" android:layout_marginBottom="24dp"
        android:textColor="#FFFFFF"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <LinearLayout android:orientation="horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center">
        <EditText android:id="@+id/etNum1" android:hint="Numerator 1"
             android:textColor="#FFFFFF"
            android:backgroundTint="#111111"
            android:inputType="numberDecimal" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
        <TextView android:text="  /  " android:textColor="#FFFFFF"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etDen1" android:hint="Denominator 1"
             android:textColor="#FFFFFF"
            android:backgroundTint="#111111"
            android:inputType="numberDecimal" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
    </LinearLayout>

    <Spinner android:id="@+id/spinnerOp"
        android:layout_width="120dp" android:layout_height="wrap_content"
        android:backgroundTint="#111111"
        android:layout_marginVertical="12dp"/>

    <LinearLayout android:orientation="horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center">
        <EditText android:id="@+id/etNum2" android:hint="Numerator 2"
             android:textColor="#FFFFFF"
            android:backgroundTint="#111111"
            android:inputType="numberDecimal" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
        <TextView android:text="  /  " android:textColor="#FFFFFF"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etDen2" android:hint="Denominator 2"
            android:textColor="#FFFFFF"
            android:backgroundTint="#111111"
            android:inputType="numberDecimal" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
    </LinearLayout>

    <Button android:id="@+id/btnCalcFraction" android:text="Calculate"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2D1B4E"
        android:textColor="#FFFFFF"/>

    <TextView android:id="@+id/tvFractionResult"
        android:textSize="24sp" android:layout_marginTop="16dp"
        android:textColor="#FFFFFF"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>