<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <TextView
            android:text="Time Zone Converter"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Time (HH:MM)"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/etTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 14:30"
            android:inputType="time"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:backgroundTint="#111111"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:text="From Time Zone"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerFromZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#111111"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:text="To Time Zone"
            android:textColor="#888888"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerToZone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#111111"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnConvertTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Convert"
            android:backgroundTint="#2D1B4E"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvTimeResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvTimeInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888888"/>

    </LinearLayout>
</ScrollView>